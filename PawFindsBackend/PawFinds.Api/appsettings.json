{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=PawFindsDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "PawFinds",
    "Audience": "PawFinds.Client",
    "SigningKey": "replace-this-development-placeholder-with-a-secret-from-user-secrets-or-key-vault",
    "AccessTokenMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
